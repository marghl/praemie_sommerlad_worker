# .env.example

# Paperless API URL aus Sicht des Containers
# Wenn Worker im selben Docker-Netz wie Paperless läuft:
# PAPERLESS_URL=http://webserver:8000
#
# Wenn Paperless extern erreichbar ist:
# PAPERLESS_URL=http://192.168.178.10:8000
PAPERLESS_URL=http://paperless:8000

# Paperless API Token
PAPERLESS_TOKEN=CHANGE_ME

# Secret für den Paperless-Webhook Header X-Worker-Token
WORKER_TOKEN=CHANGE_ME_SUPER_SECRET

# Host-Port des Workers
WORKER_PORT=8080
